# ============================================================================
# SCHOLARLY PLATFORM — UC v5.0 Environment Configuration
# ============================================================================
#
# Copy to .env and fill in values. In production, set via Azure Key Vault.
#
# ============================================================================

# ── UC Platform ──
UC_PORT=3100
UC_WS_PORT=3101
UC_LOG_LEVEL=info
UC_CORS_ORIGINS=http://localhost:3000,https://scholar.ly

# ── Scholarly Auth (JWT RS256) ──
JWT_PUBLIC_KEY=
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=RS256
JWT_ISSUER=scholarly-auth
JWT_AUDIENCE=scholarly-api

# ── NATS Event Bridge ──
NATS_URL=nats://localhost:4222
NATS_UC_PREFIX=scholarly.uc
NATS_USER=
NATS_PASS=
NATS_BIDIRECTIONAL=true
NATS_EVENT_FILTER=

# ── Multi-Tenant Isolation ──
TENANT_ISOLATION=strict

# ── Database ──
DATABASE_URL=postgresql://user:pass@localhost:5432/scholarly?schema=public

# ── UC Plugins ──
UC_ENABLED_PLUGINS=video,chat,telephony,notifications,omnichannel,ai-transcription

# ── Omnichannel Providers ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@scholar.ly
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_VERIFY_TOKEN=

# ── AI Meeting Intelligence ──
OPENAI_API_KEY=
WHISPER_ENDPOINT=http://localhost:8100/api/v1/stt/transcribe

# ── CRM Connector ──
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=
HUBSPOT_API_KEY=

# ── Stripe Connect (Tutor Onboarding Step 5) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2025-01-27.acacia
