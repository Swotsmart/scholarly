// ── Onboarding Enums ──

enum OnboardingStepEnum {
  NOT_STARTED
  IDENTITY
  BRANDING
  CALENDAR
  DOMAIN
  PAYMENTS
  PROFILE
  GO_LIVE
  COMPLETED
  ABANDONED
}

enum PersonaTypeEnum {
  TUTOR_SOLO
  TUTOR_CENTRE
}

enum DomainChoiceEnum {
  subdomain_only
  purchase_new
  transfer_existing
  point_existing
}

enum DomainStatusEnum {
  not_configured
  subdomain_active
  purchase_pending
  transfer_pending
  dns_verification_pending
  ssl_provisioning
  active
  failed
}

enum StripeOnboardingStatusEnum {
  not_started
  link_generated
  pending
  active
  restricted
  skipped
}

// ── OnboardingSession Model ──

/// Tracks a tutor's journey through the 7-step onboarding flow.
/// Each row is a complete snapshot of the onboarding state — think of it
/// as a boarding pass that accumulates stamps at each checkpoint.
///
/// The session is resumable: if the browser closes mid-step, the tutor
/// picks up exactly where they left off. The `currentStep` tracks where
/// they are now; `furthestStep` is the high-water mark showing the
/// farthest they've ever reached (allowing them to revisit earlier steps).
model OnboardingSession {
  id              String              @id @default(cuid())
  personaType     PersonaTypeEnum     @default(TUTOR_SOLO)
  currentStep     OnboardingStepEnum  @default(NOT_STARTED)
  furthestStep    OnboardingStepEnum  @default(NOT_STARTED)
  createdAt       DateTime            @default(now())
  lastActivityAt  DateTime            @default(now())
  completedAt     DateTime?

  // ── Step 1: Identity ──
  userId          String?
  tenantId        String?
  tutorProfileId  String?

  // ── Step 2: Branding ──
  providerId      String?
  subdomain       String?
  businessName    String?
  theme           Json?           // OnboardingTheme: { primaryColour, accentColour, logoUrl? }

  // ── Step 3: Calendar ──
  availabilitySlots Json  @default("[]")   // OnboardingAvailabilitySlot[]
  timezone          String?

  // ── Step 4: Domain ──
  domainType      DomainChoiceEnum?
  domainName      String?
  domainStatus    DomainStatusEnum?

  // ── Step 5: Payments ──
  stripeAccountId String?
  stripeStatus    StripeOnboardingStatusEnum?

  // ── Step 6: Profile ──
  suggestedBio    String?
  bio             String?
  socialPosts     Json    @default("[]")   // SocialPost[]
  profilePhotoUrl String?

  // ── Step 7: Go Live ──
  publishedUrl    String?

  // ── Metadata ──
  lastError       Json?           // OnboardingError: { step, code, message, timestamp, retryable }
  resumeCount     Int     @default(0)

  // Relations (optional — uncomment when merged into unified schema)
  // user            User?           @relation(fields: [userId], references: [id])
  // tenant          Tenant?         @relation(fields: [tenantId], references: [id])

  // Indices
  @@index([userId])
  @@index([tenantId])
  @@index([currentStep, lastActivityAt])
}
