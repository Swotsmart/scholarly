# ============================================================================
# Érudits Platform — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================================

# ── Server ──
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://erudits:erudits_dev@localhost:5433/erudits_dev

# ── Cache (Redis) ──
REDIS_URL=redis://localhost:6380

# ── Authentication ──
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRY=24h

# ── Stripe Connect ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PERCENT=15

# ── AI Services ──
ANTHROPIC_API_KEY=sk-ant-...
AI_MAX_TOKENS=4096
AI_DEFAULT_MODEL=claude-sonnet-4-20250514

# ── File Storage (S3-compatible) ──
S3_BUCKET=erudits-assets
S3_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=                    # Leave empty for AWS, set for MinIO/R2

# ── Email (SendGrid or AWS SES) ──
SENDGRID_API_KEY=
FROM_EMAIL=noreply@erudits.com
FROM_NAME=Érudits

# ── Squarespace Migration ──
SQUARESPACE_API_KEY=            # For API-based content extraction

# ── Content Protection ──
ENCRYPTION_MASTER_KEY=          # 32-byte hex string for AES-256 key derivation

# ── Puppeteer (PDF Rendering) ──
PUPPETEER_EXECUTABLE_PATH=      # Leave empty to use bundled Chromium
BROWSER_POOL_SIZE=2

# ── NATS (Event Bus) ──
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=erudits

# ── Logging ──
LOG_LEVEL=info                  # debug | info | warn | error
LOG_FORMAT=json                 # json | pretty
