// ============================================================================
// SCHOLARLY PLATFORM — ÉRUDITS ECOSYSTEM SCHEMA EXTENSION
// ============================================================================
//
// This schema extension adds the data models required to support the Érudits
// partnership and, by extension, every independent tutor-author on the platform.
// It covers four domains:
//
//   1. RESOURCE MARKETPLACE — Digital goods sales, licensing, and delivery
//   2. PUBLISHING ENGINE — Manuscript creation, formatting, and distribution
//   3. BOOK CLUB — Curriculum-linked reading programmes
//   4. MIGRATION — Squarespace import tracking and content mapping
//
// Design Principles:
//   - Every model carries tenantId for multi-tenant isolation.
//   - Composite unique constraints use @@unique([id, tenantId]).
//   - JSON fields store flexible configurations that vary per tenant.
//   - All financial amounts stored as integers (cents) to avoid float errors.
//   - Enum values map to string fields for Prisma compatibility.
//
// Naming Convention:
//   - Models: PascalCase (DigitalResource, BookPublication)
//   - Fields: camelCase (decodabilityScore, stripePaymentIntentId)
//   - Enums: PascalCase with SCREAMING_SNAKE values
//
// This file is intended to be merged into the unified Prisma schema.
// ============================================================================

// ============================================================================
// §1 — ENUMS
// ============================================================================

/// Status lifecycle for digital resources in the marketplace.
enum ResourceStatus {
  DRAFT           // Author is still editing
  PENDING_REVIEW  // Submitted for quality review
  APPROVED        // Passed review, ready to publish
  PUBLISHED       // Live and available for purchase
  ARCHIVED        // Removed from sale but still accessible to purchasers
  REJECTED        // Failed review
}

/// The format of a digital resource file.
enum ResourceFormat {
  PDF
  DOCX
  PPTX
  EPUB
  AUDIO_MP3
  AUDIO_WAV
  VIDEO_MP4
  IMAGE_SET      // ZIP of images
  INTERACTIVE    // HTML5 interactive resource
  OTHER
}

/// Licence scope determines who can access a purchased resource.
enum LicenceScope {
  INDIVIDUAL       // Single user
  SINGLE_SCHOOL    // All teachers at one school
  MULTI_SCHOOL     // All teachers in a school group/district
  UNLIMITED        // Open licence (e.g., Creative Commons)
}

/// Manuscript editing status in the publishing engine.
enum ManuscriptStatus {
  DRAFT
  IN_REVIEW
  REVISION_REQUESTED
  APPROVED
  FORMATTING       // Being formatted for publication
  PUBLISHED
  ARCHIVED
}

/// The format a book is published in.
enum PublicationFormat {
  EBOOK_EPUB       // Standard EPUB 3.2 for e-readers
  EBOOK_KPF        // Kindle Package Format (Amazon optimised)
  PAPERBACK        // Print-on-demand paperback
  HARDCOVER        // Print-on-demand hardcover
  DIGITAL_PDF      // Screen-optimised PDF for direct sales
  PRINT_PDF        // Print-ready PDF with trim/bleed/CMYK
  DOCX_MODIFIABLE  // Modifiable Word format (for exam packs)
}

/// Distribution channel for published books.
enum DistributionChannel {
  SCHOLARLY_DIRECT    // Sold directly through Scholarly platform
  AMAZON_KDP          // Amazon Kindle Direct Publishing
  INGRAM_SPARK        // IngramSpark (libraries, bookstores)
  SCHOLARLY_MARKETPLACE  // Other Scholarly tutors recommending/selling
  SCHOOL_DIRECT       // Institutional bulk orders
}

/// Status of a publication on a specific channel.
enum ChannelPublicationStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  LIVE
  SUSPENDED
  REMOVED
}

/// Cover design source.
enum CoverSource {
  AI_GENERATED     // Generated by GPT Image
  TEMPLATE         // Based on a platform template
  UPLOADED         // Uploaded by the author
  PROFESSIONAL     // Commissioned from a designer via platform
}

/// Book club session type.
enum BookClubSessionType {
  READING_ASSIGNMENT  // Read chapters X-Y by date
  DISCUSSION          // Live or async discussion
  ACTIVITY            // Comprehension, vocabulary, or creative activity
  ASSESSMENT          // Quiz or written response
  GUEST_SPEAKER       // Invited expert or author
}

/// Migration source platform.
enum MigrationSource {
  SQUARESPACE
  WORDPRESS
  WIX
  SHOPIFY
  TEACHERSPAYTEACHERS
  CUSTOM
}

/// Status of a migration job.
enum MigrationStatus {
  CREATED            // Job created, not yet started
  EXTRACTING         // Pulling content from source
  TRANSFORMING       // Converting to Scholarly format
  VALIDATING         // Checking converted content
  READY_FOR_REVIEW   // Awaiting human review
  APPROVED           // Review passed
  IMPORTING          // Writing to Scholarly database
  PARALLEL_RUN       // Both sites live simultaneously
  CUTOVER_READY      // Ready for DNS switch
  LIVE               // Migration complete, Scholarly is primary
  FAILED             // Something went wrong
  ROLLED_BACK        // Reverted to source platform
}

// ============================================================================
// §2 — RESOURCE MARKETPLACE MODELS
// ============================================================================

/// A sellable digital resource — the atomic unit of the marketplace.
/// For Érudits, this represents her 40+ PDFs, booklets, exam packs, and guides.
/// For the broader platform, it's any digital learning material a tutor sells.
model DigitalResource {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // ── Authorship ──
  authorId          String          // User ID of the creator
  authorName        String          // Display name (denormalised for performance)

  // ── Content Identity ──
  title             String
  slug              String          // URL-friendly identifier
  description       String          // Rich text description (Markdown)
  shortDescription  String?         // One-liner for cards and search results
  coverImageUrl     String?         // Thumbnail / preview image

  // ── Files ──
  // The actual resource files. A single resource may have multiple files
  // (e.g., a teacher guide PDF + student worksheet PDF + audio files).
  files             ResourceFile[]

  // ── Pricing ──
  // All amounts in cents to avoid floating-point errors.
  // A resource with priceIndividualCents = 0 is free.
  priceIndividualCents   Int         @default(0)
  priceSingleSchoolCents Int?        // Price for single-school licence
  priceMultiSchoolCents  Int?        // Price for multi-school licence
  currency               String      @default("AUD")

  // ── Categorisation ──
  format            ResourceFormat
  status            ResourceStatus   @default(DRAFT)
  subjectArea       String?          // e.g., "French", "Mathematics"
  yearLevels        String[]         // e.g., ["Year 11", "Year 12"]
  curriculumTags    CurriculumTag[]  // ATAR units, CEFR levels, etc.

  // ── Discoverability ──
  tags              String[]         // Free-form tags for search
  searchVector      String?          // Full-text search index content
  featured          Boolean          @default(false)
  sortOrder         Int              @default(0)

  // ── Engagement Metrics (denormalised for query performance) ──
  totalPurchases    Int              @default(0)
  totalRevenueCents Int              @default(0)
  averageRating     Float            @default(0)
  ratingCount       Int              @default(0)

  // ── Content Safety ──
  moderationStatus  String           @default("pending") // pending | approved | flagged
  moderatedAt       DateTime?
  moderatedBy       String?

  // ── Preview & Samples ──
  previewPageCount  Int?             // How many pages to show in preview
  sampleFileUrl     String?          // Free sample download URL

  // ── Relations ──
  purchases         ResourcePurchase[]
  reviews           ResourceReview[]
  protectionPolicy  ContentProtectionPolicy?

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, authorId])
  @@index([tenantId, subjectArea, status])
  @@index([tenantId, format, status])
}

/// An individual file within a digital resource.
/// A vocabulary booklet might be a single PDF; an exam pack might include
/// the exam paper, marking key, and teacher guide as separate files.
model ResourceFile {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())

  // ── Parent Resource ──
  resourceId        String
  resource          DigitalResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  // ── File Details ──
  fileName          String          // Original filename
  fileUrl           String          // S3/Cloudinary URL (never public — signed URLs only)
  fileSizeBytes     Int
  mimeType          String          // e.g., "application/pdf"
  format            ResourceFormat

  // ── Metadata ──
  label             String?         // "Teacher Guide", "Student Worksheet", "Audio"
  sortOrder         Int             @default(0)
  pageCount         Int?            // For PDFs
  durationSeconds   Int?            // For audio/video

  // ── DRM ──
  watermarkEnabled  Boolean         @default(false)

  @@index([resourceId])
  @@index([tenantId, resourceId])
}

/// A purchase record — one per buyer per resource (or per licence for schools).
model ResourcePurchase {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())

  // ── What was purchased ──
  resourceId        String
  resource          DigitalResource @relation(fields: [resourceId], references: [id])

  // ── Who purchased it ──
  buyerId           String          // User ID
  buyerEmail        String
  buyerName         String

  // ── Payment Details ──
  amountCents       Int             // Amount charged
  currency          String          @default("AUD")
  platformFeeCents  Int             // Scholarly's commission
  authorEarningsCents Int           // Author's share
  stripePaymentIntentId String?     // Stripe PI for reconciliation
  stripeChargeId    String?

  // ── Licence ──
  licenceScope      LicenceScope    @default(INDIVIDUAL)
  licence           ResourceLicence?

  // ── Status ──
  status            String          @default("completed") // completed | refunded | disputed
  refundedAt        DateTime?
  refundAmountCents Int?

  // ── Download Tracking ──
  downloadCount     Int             @default(0)
  lastDownloadedAt  DateTime?

  @@index([tenantId, resourceId])
  @@index([tenantId, buyerId])
  @@index([stripePaymentIntentId])
}

/// An active licence granting access to a resource for a specific scope.
/// For Érudits' exam packs: a school purchases a single-school licence for $280,
/// which allows all French teachers at that school to access and modify the pack.
model ResourceLicence {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // ── Purchase Link ──
  purchaseId        String          @unique
  purchase          ResourcePurchase @relation(fields: [purchaseId], references: [id])

  // ── Scope ──
  scope             LicenceScope
  institutionId     String?         // School/org ID for institutional licences
  institutionName   String?         // Denormalised for display

  // ── Access Control ──
  maxUsers          Int?            // null = unlimited within scope
  activeUsers       Int             @default(0)
  expiresAt         DateTime?       // null = perpetual

  // ── Status ──
  isActive          Boolean         @default(true)
  deactivatedAt     DateTime?
  deactivationReason String?

  // ── Relations ──
  protectedDevices  ProtectedDeviceRegistration[]

  @@index([tenantId, institutionId])
  @@index([tenantId, scope, isActive])
}

/// Ratings and reviews from resource buyers.
model ResourceReview {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  resourceId        String
  resource          DigitalResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  reviewerId        String
  reviewerName      String

  rating            Int             // 1-5 stars
  title             String?
  body              String?         // Review text (Markdown)

  // Moderation
  isPublished       Boolean         @default(true)
  moderatedAt       DateTime?
  moderatedBy       String?

  @@unique([resourceId, reviewerId])
  @@index([tenantId, resourceId])
}

// ============================================================================
// §3 — PUBLISHING ENGINE MODELS
// ============================================================================

/// A book manuscript in the publishing engine.
/// This is the authoring workspace — the manuscript content, metadata,
/// version history, and publication state.
model Manuscript {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // ── Authorship ──
  authorId          String
  authorName        String
  collaboratorIds   String[]          // Co-authors with edit access

  // ── Identity ──
  title             String
  subtitle          String?
  slug              String
  description       String?           // Book blurb / back cover text
  language          String            @default("en")
  secondaryLanguage String?           // For bilingual books (e.g., "fr" for Érudits)

  // ── Content ──
  // Manuscript content stored as ProseMirror JSON document.
  // This enables rich collaborative editing, version comparison,
  // and structured content extraction for formatting.
  content           Json              // ProseMirror document JSON
  wordCount         Int               @default(0)
  pageCountEstimate Int               @default(0)

  // ── Structure ──
  chapters          ManuscriptChapter[]
  frontMatter       Json?             // Title page, copyright, dedication, TOC config
  backMatter        Json?             // About author, index, bibliography config

  // ── Classification ──
  genre             String?           // "language_textbook", "workbook", "exam_guide", etc.
  subjectArea       String?
  yearLevels        String[]
  curriculumTags    CurriculumTag[]

  // ── Print Specifications ──
  trimWidth         Float?            // Inches (e.g., 6.0)
  trimHeight        Float?            // Inches (e.g., 9.0)
  paperType         String?           // "white", "cream"
  inkType           String?           // "black", "standard_color", "premium_color"
  bindingType       String?           // "paperback", "hardcover"
  hasBleed          Boolean           @default(false)

  // ── ISBN ──
  isbnEbook         String?
  isbnPaperback     String?
  isbnHardcover     String?

  // ── Status ──
  status            ManuscriptStatus  @default(DRAFT)
  currentVersionId  String?

  // ── Relations ──
  versions          ManuscriptVersion[]
  publications      BookPublication[]
  covers            BookCover[]

  @@unique([tenantId, slug])
  @@index([tenantId, authorId])
  @@index([tenantId, status])
}

/// A chapter within a manuscript — for structural navigation and per-chapter
/// metadata (useful for curriculum-linked content where each chapter maps
/// to a different unit or topic).
model ManuscriptChapter {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  manuscriptId      String
  manuscript        Manuscript      @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)

  title             String
  sortOrder         Int
  wordCount         Int             @default(0)
  pageStart         Int?            // Estimated starting page

  // ── Curriculum Alignment ──
  // Each chapter can target specific curriculum elements.
  // For Érudits: Chapter 1 → ATAR Unit 1, Chapter 2 → ATAR Unit 2, etc.
  curriculumCode    String?         // e.g., "WACE_FR_SL_U1"
  learningObjectives String[]

  // ── Content Reference ──
  // Points to a specific node in the ProseMirror JSON document tree.
  contentNodeId     String?

  @@index([manuscriptId, sortOrder])
}

/// An immutable snapshot of a manuscript at a point in time.
/// Enables rollback, comparison, and branching (2025 vs 2026 editions).
model ManuscriptVersion {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())

  manuscriptId      String
  manuscript        Manuscript      @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)

  versionNumber     Int
  label             String?         // "2025 Edition", "Draft 3", "Post-Review"
  content           Json            // Full ProseMirror document snapshot
  wordCount         Int
  changeDescription String?         // What changed from previous version

  createdBy         String          // User ID who saved this version

  @@unique([manuscriptId, versionNumber])
  @@index([manuscriptId])
}

/// A published book derived from a manuscript.
/// One manuscript can have multiple publications: ebook, paperback, digital PDF.
/// Each publication tracks its status on each distribution channel independently.
model BookPublication {
  id                String                @id @default(cuid())
  tenantId          String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  // ── Source Manuscript ──
  manuscriptId      String
  manuscript        Manuscript            @relation(fields: [manuscriptId], references: [id])
  versionId         String                // Which version was published

  // ── Publication Format ──
  format            PublicationFormat
  fileUrl           String?               // Generated file URL (EPUB, PDF, etc.)
  fileSizeBytes     Int?
  pageCount         Int?
  spineWidthInches  Float?                // Calculated from page count + paper type

  // ── Cover ──
  coverId           String?
  cover             BookCover?            @relation(fields: [coverId], references: [id])

  // ── Pricing (per channel, stored as JSON for flexibility) ──
  // Structure: { "SCHOLARLY_DIRECT": { "priceCents": 2500, "currency": "AUD" }, ... }
  pricing           Json

  // ── Distribution Channels ──
  channels          PublicationChannel[]

  // ── Aggregate Metrics ──
  totalSales        Int                   @default(0)
  totalRevenueCents Int                   @default(0)
  averageRating     Float                 @default(0)

  // ── Amazon KDP Specifics ──
  kdpAsin           String?               // Amazon Standard Identification Number
  kdpStatus         String?               // "draft", "in_review", "live", "suppressed"
  kdpLastSyncAt     DateTime?

  // ── IngramSpark Specifics ──
  ingramTitleId     String?
  ingramStatus      String?
  ingramLastSyncAt  DateTime?

  @@index([tenantId, manuscriptId])
  @@index([tenantId, format])
  @@index([kdpAsin])
}

/// Tracks a publication's status on a specific distribution channel.
/// Allows independent lifecycle management per channel.
model PublicationChannel {
  id                String                  @id @default(cuid())
  tenantId          String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  publicationId     String
  publication       BookPublication         @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  channel           DistributionChannel
  status            ChannelPublicationStatus @default(NOT_SUBMITTED)
  externalId        String?                 // Channel-specific ID (ASIN, Ingram Title ID, etc.)

  // ── Pricing for this channel ──
  listPriceCents    Int?
  currency          String                  @default("AUD")
  royaltyPercent    Float?                  // Expected royalty rate

  // ── Submission & Review ──
  submittedAt       DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?

  // ── Sync ──
  lastSyncAt        DateTime?
  syncErrors        Json?                   // Array of recent sync errors

  @@unique([publicationId, channel])
  @@index([tenantId, channel, status])
}

/// A book cover design — may be AI-generated, template-based, or uploaded.
model BookCover {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  manuscriptId      String
  source            CoverSource

  // ── Image Files ──
  // Front cover is always required. Full cover (with spine + back) is
  // needed for print formats.
  frontCoverUrl     String?         // Front cover image
  fullCoverUrl      String?         // Full wraparound cover (front + spine + back)
  thumbnailUrl      String?         // Low-res thumbnail for listings

  // ── Specifications ──
  widthPx           Int?
  heightPx          Int?
  dpiResolution     Int?            // 300 for print, 72 for digital
  colourSpace       String?         // "RGB" or "CMYK"
  spineWidthInches  Float?          // Calculated from page count

  // ── AI Generation Details ──
  aiPrompt          String?         // The prompt used to generate the cover
  aiModel           String?         // "gpt-image-1.5", etc.
  aiGenerationCost  Float?          // API cost in USD

  // ── Template Details ──
  templateId        String?         // Platform template used
  templateCustomisations Json?      // Overridden colours, fonts, text

  // ── Validation ──
  isKdpCompliant    Boolean         @default(false)
  validationErrors  Json?           // Array of spec compliance issues
  validatedAt       DateTime?

  // ── Selection ──
  isSelected        Boolean         @default(false) // The chosen cover for this manuscript

  // ── Relations ──
  publications      BookPublication[]

  @@index([manuscriptId])
  @@index([tenantId, manuscriptId, isSelected])
}

/// A sales record spanning all distribution channels.
/// One record per individual sale or institutional order line.
model SalesRecord {
  id                String               @id @default(cuid())
  tenantId          String
  createdAt         DateTime             @default(now())

  // ── What was sold ──
  publicationId     String?              // Book publication (null for resource sales)
  resourceId        String?              // Digital resource (null for book sales)
  channel           DistributionChannel

  // ── Buyer ──
  buyerId           String?              // Scholarly user ID (null for external sales)
  buyerEmail        String?
  institutionId     String?              // For school orders

  // ── Financials ──
  quantitySold      Int                  @default(1)
  unitPriceCents    Int
  totalPriceCents   Int
  platformFeeCents  Int                  // Scholarly's commission
  channelFeeCents   Int                  // Amazon/Ingram/Stripe fees
  authorEarningsCents Int                // What the author actually receives
  currency          String               @default("AUD")

  // ── Payment Reconciliation ──
  stripePaymentIntentId String?
  externalTransactionId String?          // KDP/IngramSpark transaction ID
  payoutId          String?              // Linked to payment service payout
  reconciledAt      DateTime?

  // ── Metadata ──
  countryCode       String?              // Buyer's country (for tax/reporting)
  isRefunded        Boolean              @default(false)
  refundedAt        DateTime?

  @@index([tenantId, channel])
  @@index([tenantId, publicationId])
  @@index([tenantId, resourceId])
  @@index([tenantId, createdAt])
  @@index([stripePaymentIntentId])
}

// ============================================================================
// §4 — BOOK CLUB MODELS
// ============================================================================

/// A book club instance — a structured reading programme run by a tutor.
/// For Érudits: her "Érudits Curriculum Book Club" with scheduled readings
/// linked to ATAR units.
model BookClub {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // ── Organiser ──
  organiserId       String          // Tutor who runs the club
  organiserName     String

  // ── Identity ──
  name              String
  slug              String
  description       String?
  coverImageUrl     String?
  language          String          @default("fr")

  // ── Configuration ──
  maxParticipants   Int?            // null = unlimited
  isPublic          Boolean         @default(true)
  requiresApproval  Boolean         @default(false)
  subscriptionRequired Boolean      @default(false)

  // ── Curriculum Link ──
  subjectArea       String?
  yearLevels        String[]
  curriculumTags    CurriculumTag[]

  // ── Schedule ──
  startDate         DateTime?
  endDate           DateTime?
  meetingFrequency  String?         // "weekly", "fortnightly", "monthly"
  meetingDay        String?         // "Tuesday"
  meetingTime       String?         // "16:00"
  timezone          String          @default("Australia/Perth")

  // ── Status ──
  isActive          Boolean         @default(true)
  participantCount  Int             @default(0)

  // ── Relations ──
  sessions          BookClubSession[]
  members           BookClubMember[]
  readingList       BookClubReading[]

  @@unique([tenantId, slug])
  @@index([tenantId, organiserId])
  @@index([tenantId, isActive, isPublic])
}

/// A scheduled session within a book club.
model BookClubSession {
  id                String              @id @default(cuid())
  tenantId          String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  bookClubId        String
  bookClub          BookClub            @relation(fields: [bookClubId], references: [id], onDelete: Cascade)

  // ── Session Details ──
  title             String
  description       String?
  sessionType       BookClubSessionType
  scheduledAt       DateTime
  durationMinutes   Int                 @default(60)
  sortOrder         Int

  // ── Reading Assignment ──
  readingId         String?             // Which book/reading this session covers
  reading           BookClubReading?    @relation(fields: [readingId], references: [id])
  chaptersFrom      String?             // "Chapter 3"
  chaptersTo        String?             // "Chapter 5"
  pagesFrom         Int?
  pagesTo           Int?

  // ── Meeting Details ──
  meetingUrl        String?             // Video call link
  location          String?             // Physical location

  // ── Content ──
  discussionPrompts Json?               // Array of discussion questions
  materials         Json?               // Attached worksheets, vocab lists, etc.

  // ── Status ──
  status            String              @default("scheduled") // scheduled | in_progress | completed | cancelled

  @@index([bookClubId, scheduledAt])
}

/// A book on the club's reading list.
model BookClubReading {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())

  bookClubId        String
  bookClub          BookClub        @relation(fields: [bookClubId], references: [id], onDelete: Cascade)

  // ── Book Identity ──
  title             String
  author            String
  isbn              String?
  coverImageUrl     String?
  publicationId     String?         // If it's a Scholarly-published book

  // ── Schedule ──
  sortOrder         Int
  startDate         DateTime?
  endDate           DateTime?

  // ── Curriculum Link ──
  curriculumCode    String?
  learningObjectives String[]

  // ── Relations ──
  sessions          BookClubSession[]

  @@index([bookClubId, sortOrder])
}

/// A member of a book club.
model BookClubMember {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())

  bookClubId        String
  bookClub          BookClub        @relation(fields: [bookClubId], references: [id], onDelete: Cascade)

  userId            String
  displayName       String
  role              String          @default("member") // member | moderator | organiser

  // ── Engagement ──
  sessionsAttended  Int             @default(0)
  lastActiveAt      DateTime?

  @@unique([bookClubId, userId])
  @@index([tenantId, userId])
}

// ============================================================================
// §5 — CURRICULUM TAG MODEL
// ============================================================================

/// A flexible curriculum alignment tag that can be attached to resources,
/// manuscripts, and book clubs. This replaces hard-coded curriculum fields
/// with a taggable system that supports any framework worldwide.
model CurriculumTag {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())

  // ── Tag Identity ──
  framework         String          // "WACE_ATAR", "CEFR", "IB_PYP", "ACARA", "EYLF", "EYFS"
  code              String          // "FR_SL_U1", "B2", "PYP_LANG_PHASE4"
  label             String          // "French Second Language ATAR Unit 1"
  description       String?

  // ── Hierarchy ──
  parentId          String?
  level             Int             @default(0) // 0 = top-level framework, 1 = strand, 2 = unit, etc.

  // ── Relations ──
  resources         DigitalResource[]
  manuscripts       Manuscript[]
  bookClubs         BookClub[]

  @@unique([tenantId, framework, code])
  @@index([tenantId, framework])
}

// ============================================================================
// §6 — MIGRATION TRACKING MODELS
// ============================================================================

/// A migration job tracking the import from an external platform.
/// One job per tutor per source platform migration.
model PlatformMigration {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // ── Source ──
  source            MigrationSource
  sourceUrl         String          // e.g., "https://erudits.com"
  sourceSiteId      String?         // Platform-specific site ID

  // ── Owner ──
  ownerId           String          // User who initiated the migration
  ownerEmail        String

  // ── Status ──
  status            MigrationStatus @default(CREATED)
  currentStep       String?         // Human-readable current step
  progressPercent   Int             @default(0)

  // ── Content Inventory ──
  // Discovered content counts from the source platform.
  pagesFound        Int             @default(0)
  productsFound     Int             @default(0)
  membersFound      Int             @default(0)
  imagesFound       Int             @default(0)
  postsFound        Int             @default(0)

  // ── Import Results ──
  pagesImported     Int             @default(0)
  productsImported  Int             @default(0)
  membersImported   Int             @default(0)
  imagesImported    Int             @default(0)
  postsImported     Int             @default(0)

  // ── Mapping ──
  // JSON map of source URLs → Scholarly URLs for 301 redirects.
  urlMappings       Json?

  // ── DNS ──
  customDomain      String?         // The domain being migrated (e.g., "erudits.com")
  dnsVerified       Boolean         @default(false)
  sslProvisioned    Boolean         @default(false)

  // ── Timing ──
  extractionStartedAt   DateTime?
  extractionCompletedAt DateTime?
  importStartedAt       DateTime?
  importCompletedAt     DateTime?
  cutoverAt             DateTime?

  // ── Error Tracking ──
  errors            Json?           // Array of { step, message, details, timestamp }
  warnings          Json?           // Non-fatal issues found during migration

  // ── Relations ──
  contentItems      MigrationContentItem[]

  @@index([tenantId, ownerId])
  @@index([tenantId, status])
}

/// An individual content item being migrated from the source platform.
/// Tracks the mapping from source content to Scholarly entities.
model MigrationContentItem {
  id                String          @id @default(cuid())
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  migrationId       String
  migration         PlatformMigration @relation(fields: [migrationId], references: [id], onDelete: Cascade)

  // ── Source Content ──
  sourceType        String          // "page", "product", "post", "image", "member"
  sourceId          String?         // Platform-specific content ID
  sourceUrl         String?         // Original URL
  sourceTitle       String?
  sourceData        Json?           // Raw extracted data from source

  // ── Target Mapping ──
  targetType        String?         // "cms_page", "digital_resource", "user", "media"
  targetId          String?         // ID of created Scholarly entity
  targetUrl         String?         // New Scholarly URL

  // ── Status ──
  status            String          @default("pending") // pending | mapped | imported | failed | skipped
  errorMessage      String?
  requiresReview    Boolean         @default(false)
  reviewNotes       String?

  @@index([migrationId, sourceType])
  @@index([migrationId, status])
}

// ============================================================================
// §5 — STORYBOOK ENGINE (SSE)
// ============================================================================
//
// The Storybook Engine models underpin the curriculum-aligned, decodable
// storybook generation pipeline. While the Érudits domains above serve
// tutor-authors who create and sell their own content, the SSE serves the
// phonics learning pipeline: AI-generated storybooks calibrated to each
// learner's mastery profile.
//
// Think of it as two wings of the same building: the Érudits wing is a
// marketplace where educators sell their expertise; the SSE wing is a
// magical library where every book is precisely engineered for the child
// reading it. Both share the same foundation (types, events, repositories)
// and the same AI backends (Claude, GPT Image, Voice Service).
// ============================================================================

/// Storybook lifecycle status.
enum StorybookStatus {
  GENERATING        // AI is creating the narrative
  ILLUSTRATING      // Illustration pipeline is running
  NARRATING         // Audio generation in progress
  DRAFT             // Complete but not reviewed
  IN_REVIEW         // In the 5-stage quality gate
  APPROVED          // Passed review, ready for library
  PUBLISHED         // Live in the library
  ARCHIVED          // Removed from active library
  FAILED            // Generation or review failed
}

/// Art style for illustration generation.
enum ArtStyle {
  WATERCOLOUR
  FLAT_VECTOR
  SOFT_3D
  CRAYON
  PAPERCRAFT
  STORYBOOK_CLASSIC
  ANIME_SOFT
  PIXEL_ART
  COLLAGE
  PENCIL_SKETCH
  GOUACHE
  DIGITAL_PAINT
  WOODBLOCK
  LINOCUT
  POP_ART
}

/// Creator tier in the community content ecosystem.
enum CreatorTier {
  BRONZE            // Automated validation only
  SILVER            // Peer-reviewed, full distribution
  GOLD              // Consistently high engagement
  PLATINUM          // Verified educator credentials
}

/// Review stage in the 5-stage quality gate.
enum ReviewStage {
  AUTOMATED_VALIDATION
  AI_REVIEW
  PEER_REVIEW
  PILOT_TESTING
  LIBRARY_PUBLICATION
}

/// Content bounty status.
enum BountyStatus {
  OPEN              // Accepting submissions
  IN_PROGRESS       // Submissions being reviewed
  AWARDED           // Winner selected
  CANCELLED         // Bounty withdrawn
  EXPIRED           // Deadline passed with no winner
}

/// The core storybook entity. Each book is a curriculum-aligned,
/// decodable story targeting specific grapheme-phoneme correspondences.
/// Think of it as a book that knows which letters it's teaching.
model Storybook {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // ── Identity ──
  title             String
  slug              String
  description       String?
  status            StorybookStatus   @default(GENERATING)

  // ── Authorship ──
  creatorId         String            // User or AI system ID
  creatorType       String            @default("ai") // "ai" | "community" | "internal"
  seriesId          String?
  series            StorybookSeries?  @relation(fields: [seriesId], references: [id])
  seriesOrder       Int?              // Position within series

  // ── Phonics Metadata ──
  phonicsPhase      Int               // Letters & Sounds phase (1-6)
  targetGpcs        Json              // String[] — GPCs this book practises
  taughtGpcSet      Json              // String[] — Full GPC set required
  decodabilityScore Float             @default(0) // 0.0–1.0 (minimum 0.85)
  wcpmBand          Json?             // { min: number, max: number }
  vocabularyTier    String            @default("tier_1") // tier_1, tier_2, tier_3
  morphemeFocus     Json?             // String[] — prefixes, suffixes, roots
  comprehensionStrand String?         // Reading Rope strand emphasised

  // ── Curriculum Alignment ──
  eylfAlignment     Json?             // EYLF/EYFS outcome mappings
  ibPypAlignment    Json?             // IB PYP transdisciplinary themes
  culturalContext   Json?             // Cultural setting & representation tags

  // ── Content ──
  ageGroupMin       Int               @default(3)
  ageGroupMax       Int               @default(7)
  artStyle          ArtStyle          @default(WATERCOLOUR)
  themes            Json              // String[] — e.g., ["animals", "adventure"]
  narrativeTemplate String?           // Template ID used for generation
  pageCount         Int               @default(0)

  // ── Generation Metadata ──
  generationCost    Float             @default(0) // Total API cost in USD
  generationModel   String?           // Claude model used
  generationPrompt  Json?             // The phonics fingerprint used

  // ── Relations ──
  pages             StorybookPage[]
  illustrations     StorybookIllustration[]
  reviews           StorybookReview[]
  analytics         StorybookAnalytics?
  deviceBooks       DeviceStorybook[]

  @@unique([id, tenantId])
  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, phonicsPhase])
  @@index([tenantId, creatorId])
  @@index([tenantId, seriesId])
}

/// Individual page within a storybook. Each page carries text, illustration,
/// audio narration, and word-level timestamps for karaoke-style highlighting.
model StorybookPage {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())

  storybookId       String
  storybook         Storybook         @relation(fields: [storybookId], references: [id], onDelete: Cascade)
  pageNumber        Int

  // ── Content ──
  text              String            // The page text (decodable)
  illustrationUrl   String?           // Generated illustration URL
  audioUrl          String?           // Narration audio URL
  wordTimestamps    Json?             // Array of { word, startMs, endMs }

  // ── Scene Layout ──
  sceneLayout       Json?             // Layer decomposition for parallax
  textOverlayZone   Json?             // { x, y, width, height } for text placement

  // ── Decodability ──
  decodableWords    Json?             // String[] — words decodable with taught GPCs
  nonDecodableWords Json?             // String[] — words outside taught set (<=15%)

  @@unique([storybookId, pageNumber])
  @@index([tenantId, storybookId])
}

/// Character definitions that persist across books in a series.
/// The character sheet maintains visual consistency — the holy grail
/// of AI-generated children's book illustration.
model StorybookCharacter {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // ── Identity ──
  name              String
  description       String            // Detailed text description for prompts
  personalityTraits Json?             // String[] — for narrative consistency

  // ── Visual Reference ──
  styleSheetUrl     String?           // Reference image URL
  stylePrompt       String?           // Detailed visual description for image gen
  artStyle          ArtStyle?

  // ── Series Association ──
  seriesId          String?
  series            StorybookSeries?  @relation(fields: [seriesId], references: [id])

  // ── Creator ──
  creatorId         String

  @@unique([id, tenantId])
  @@index([tenantId, seriesId])
  @@index([tenantId, creatorId])
}

/// Series metadata linking multiple storybooks with shared characters
/// and narrative arcs. "What happens to Finn the Fox next?"
model StorybookSeries {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  name              String
  slug              String
  description       String?
  theme             String?
  narrativeArc      String?           // Summary of the overarching story

  // ── Phonics Targeting ──
  targetPhases      Json              // Int[] — phonics phases this series covers
  ageGroupMin       Int               @default(3)
  ageGroupMax       Int               @default(7)

  // ── Art ──
  artStyle          ArtStyle          @default(WATERCOLOUR)
  coverImageUrl     String?

  // ── Creator ──
  creatorId         String

  // ── Relations ──
  books             Storybook[]
  characters        StorybookCharacter[]

  @@unique([id, tenantId])
  @@unique([tenantId, slug])
  @@index([tenantId, creatorId])
}

/// Record of each generated illustration. Tracks the prompt, model, style,
/// and generation cost for reproducibility and cost analysis.
model StorybookIllustration {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())

  storybookId       String
  storybook         Storybook         @relation(fields: [storybookId], references: [id], onDelete: Cascade)
  pageNumber        Int?

  // ── Generation Details ──
  prompt            String            @db.Text
  negativePrompt    String?
  model             String            // "gpt-image-1", "sd-3.5", etc.
  artStyle          ArtStyle
  seed              Int?              // For reproducibility
  imageUrl          String
  thumbnailUrl      String?

  // ── Quality ──
  moderationResult  Json?             // Safety check results
  moderationPassed  Boolean           @default(true)

  // ── Cost ──
  generationCost    Float             @default(0)

  @@index([tenantId, storybookId])
}

/// Review records from the 5-stage quality gate pipeline.
/// Each storybook accumulates reviews as it progresses through
/// automated → AI → peer → pilot → publication stages.
model StorybookReview {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())

  storybookId       String
  storybook         Storybook         @relation(fields: [storybookId], references: [id], onDelete: Cascade)

  // ── Review Details ──
  stage             ReviewStage
  reviewerId        String?           // null for automated/AI reviews
  reviewerType      String            @default("automated") // "automated" | "ai" | "educator"

  // ── Scores ──
  overallScore      Float?            // 0.0–5.0
  decodabilityOk    Boolean           @default(false)
  safetyOk          Boolean           @default(false)
  curriculumAligned Boolean           @default(false)
  narrativeCoherent Boolean           @default(false)
  ageAppropriate    Boolean           @default(false)

  // ── Feedback ──
  comments          String?           @db.Text
  structuredReport  Json?             // Detailed review breakdown

  // ── Decision ──
  passed            Boolean           @default(false)

  @@index([tenantId, storybookId])
  @@index([tenantId, stage])
  @@index([tenantId, reviewerId])
}

/// Per-book engagement analytics. Updated as children read the book.
/// This data feeds back into the recommendation engine and helps
/// identify which books are working and which need improvement.
model StorybookAnalytics {
  id                String            @id @default(cuid())
  tenantId          String
  updatedAt         DateTime          @updatedAt

  storybookId       String            @unique
  storybook         Storybook         @relation(fields: [storybookId], references: [id], onDelete: Cascade)

  // ── Engagement ──
  readCount         Int               @default(0)
  uniqueReaders     Int               @default(0)
  completionRate    Float             @default(0) // 0.0–1.0
  reReadRate        Float             @default(0) // Proportion who read it again
  avgTimeSeconds    Int               @default(0)

  // ── Learning Outcomes ──
  avgAccuracy       Float             @default(0) // Word-level accuracy
  avgWcpm           Float             @default(0) // Words correct per minute
  gpcMasteryImpact  Json?             // How much this book improved GPC mastery

  // ── Ratings ──
  avgRating         Float             @default(0)
  ratingCount       Int               @default(0)

  @@index([tenantId])
}

/// Developer/creator profiles for the community content ecosystem.
/// Creators earn tiers, XP, and revenue share based on the quality
/// and engagement of their contributed storybooks.
model CreatorProfile {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  userId            String
  displayName       String
  bio               String?
  avatarUrl         String?

  // ── Status ──
  tier              CreatorTier       @default(BRONZE)
  isVerifiedEducator Boolean          @default(false)
  verificationDate  DateTime?

  // ── Metrics ──
  totalContributions Int              @default(0)
  publishedBooks    Int               @default(0)
  totalReads        Int               @default(0)
  engagementScore   Float             @default(0)
  reviewsCompleted  Int               @default(0)

  // ── Earnings ──
  totalEarningsCents Int              @default(0)
  pendingPayoutCents Int              @default(0)
  stripeConnectId   String?

  // ── Content Bounties ──
  bountiesWon       Int               @default(0)

  @@unique([id, tenantId])
  @@unique([tenantId, userId])
  @@index([tenantId, tier])
}

/// Content bounties: specific content needs that creators compete to fill.
/// "We need Phase 3 storybooks about Australian animals for ages 5–7."
model ContentBounty {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // ── Requirements ──
  title             String
  description       String            @db.Text
  phonicsPhase      Int?
  targetGpcs        Json?             // String[]
  ageGroupMin       Int?
  ageGroupMax       Int?
  themes            Json?             // String[]
  artStyle          ArtStyle?

  // ── Reward ──
  rewardCents       Int               @default(0)
  rewardCurrency    String            @default("AUD")
  fundingSource     String            @default("dao_treasury") // "dao_treasury" | "platform" | "sponsor"

  // ── Status ──
  status            BountyStatus      @default(OPEN)
  deadline          DateTime?
  submissionCount   Int               @default(0)

  // ── Winner ──
  winnerId          String?           // CreatorProfile.userId
  winningBookId     String?           // Storybook.id
  awardedAt         DateTime?

  // ── Creator ──
  postedBy          String            // Admin or DAO proposal ID

  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, phonicsPhase])
}

/// Tracks which storybooks are downloaded on which devices.
/// Enables offline reading and cross-device sync without
/// re-downloading automatically (respecting data limits).
model DeviceStorybook {
  id                String            @id @default(cuid())
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // ── Device ──
  deviceId          String            // From PhonicsDeviceRegistration
  userId            String

  // ── Book ──
  storybookId       String
  storybook         Storybook         @relation(fields: [storybookId], references: [id])

  // ── Sync State ──
  downloadStatus    String            @default("pending") // pending | downloading | complete | failed
  storageSizeBytes  Int               @default(0)
  syncVersion       Int               @default(1)
  lastAccessedAt    DateTime?

  // ── Reading Position ──
  currentPage       Int               @default(0)
  currentWordIndex  Int               @default(0)
  completedAt       DateTime?

  @@unique([deviceId, storybookId])
  @@index([tenantId, userId])
  @@index([tenantId, deviceId])
}

// =============================================================================
// §6 — CONTENT PROTECTION
// =============================================================================
// Four-layer defence-in-depth for high-value educational content.
// Layer 1: Forensic Watermarking (visible + steganographic)
// Layer 2: Licence Enforcement (device binding, session limits)
// Layer 3: Encrypted Reader (server-side decryption, anti-screenshot)
// Layer 4: Download Protection (AES-256-GCM, PDF permissions)

/// Protection levels: basic | standard | premium | maximum
enum ProtectionLevel {
  basic          // Layer 1 only
  standard       // Layers 1 + 2
  premium        // Layers 1 + 2 + 3
  maximum        // All 4 layers
}

/// Content delivery mode: how the buyer accesses the content
enum DeliveryMode {
  download       // Downloadable file (with protection layers applied)
  reader_only    // Browser-based reader only (no file download)
  both           // Both modes available
}

/// Device platform for fingerprinting strategy selection
enum DevicePlatform {
  ios
  android
  web
  desktop_mac
  desktop_win
  desktop_linux
}

/// Device registration lifecycle
enum DeviceStatus {
  active
  suspended
  deregistered
  expired
}

/// Violation severity for automated response selection
enum ViolationSeverity {
  low
  medium
  high
  critical
}

/// Action taken in response to a detected violation
enum ViolationAction {
  flag_for_review
  send_warning
  suspend_licence
  revoke_licence
  legal_escalation
}

/// Per-resource protection configuration. Authors set this through
/// the storefront dashboard to control how their content is protected.
model ContentProtectionPolicy {
  id                        String          @id @default(cuid())
  tenantId                  String
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  // ── Resource Link ──
  resourceId                String          @unique
  resource                  DigitalResource @relation(fields: [resourceId], references: [id])

  // ── Protection Level ──
  protectionLevel           ProtectionLevel @default(basic)
  deliveryMode              DeliveryMode    @default(download)

  // ── Layer 1: Watermarking ──
  visibleWatermark          Boolean         @default(true)
  watermarkText             String?         // Override; null = derive from licence
  steganographicEnabled     Boolean         @default(false)
  steganographicTechniques  String[]        // ['micro_typography', 'homoglyph']

  // ── Layer 2: Licence Enforcement ──
  maxDevicesIndividual      Int             @default(3)
  maxDevicesInstitution     Int             @default(10)
  concurrentSessionLimit    Int             @default(5)
  sessionTimeoutMinutes     Int             @default(480)

  // ── Layer 3: Encrypted Reader ──
  readerEnabled             Boolean         @default(false)
  antiScreenshotOverlay     Boolean         @default(true)
  overlayRefreshSeconds     Int             @default(30)
  focusBlurEnabled          Boolean         @default(false)
  pageRateLimitPerMinute    Int             @default(30)

  // ── Layer 4: Download Protection ──
  downloadEncrypted         Boolean         @default(false)
  pdfPermissions            String[]        // ['print_high_quality', 'fill_forms']
  downloadLimitPerDevice    Int             @default(5)

  // ── Automated Response ──
  autoSuspendOnViolation    Boolean         @default(false)
  violationNotifyAuthor     Boolean         @default(true)
  violationNotifyAdmin      Boolean         @default(true)

  @@unique([resourceId, tenantId])
  @@index([tenantId])
}

/// A trusted device registered against a licence. The "key card"
/// that grants access to protected content on a specific device.
model ProtectedDeviceRegistration {
  id                        String          @id @default(cuid())
  tenantId                  String
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  // ── Licence Link ──
  licenceId                 String
  licence                   ResourceLicence @relation(fields: [licenceId], references: [id])
  userId                    String

  // ── Device Identity ──
  fingerprint               String          // Composite hash
  fingerprintComponents     Json            // Raw device attributes
  deviceName                String          // "Sarah's iPad"
  platform                  DevicePlatform

  // ── Status ──
  status                    DeviceStatus    @default(active)
  lastSeenAt                DateTime        @default(now())
  lastIpAddress             String?
  lastAccessedResourceId    String?

  // ── Deregistration ──
  deregisteredAt            DateTime?
  deregisteredBy            String?
  deregistrationReason      String?

  // ── Relations ──
  downloadRecords           DownloadRecord[]

  @@unique([licenceId, fingerprint])
  @@index([tenantId, licenceId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
}

/// Forensic record of every protected file download. The evidence
/// chain linking a leaked file back to a specific person and device.
model DownloadRecord {
  id                        String          @id @default(cuid())
  tenantId                  String
  createdAt                 DateTime        @default(now())

  // ── Purchase & Licence ──
  purchaseId                String
  licenceId                 String
  userId                    String
  resourceId                String
  fileId                    String

  // ── Device ──
  deviceRegistrationId      String
  device                    ProtectedDeviceRegistration @relation(fields: [deviceRegistrationId], references: [id])
  deviceFingerprint         String

  // ── Steganographic Fingerprint ──
  steganographicFingerprint String          // 64-bit fingerprint as hex
  fingerprintBits           Json            // { purchaseHash, userHash, timestampMod, deviceHash, checksum }

  // ── Watermark Layers ──
  watermarkLayers           String[]        // ['visible_text', 'metadata', 'steganographic']
  watermarkText             String

  // ── Context ──
  ipAddress                 String
  userAgent                 String
  fileHash                  String          // SHA-256 of the delivered file
  fileSizeBytes             Int

  // ── Encryption ──
  encrypted                 Boolean         @default(false)
  encryptionKeyVersion      Int?

  // ── Relations ──
  violations                ContentViolation[]

  @@index([tenantId, resourceId])
  @@index([tenantId, userId])
  @@index([steganographicFingerprint])
  @@index([tenantId, purchaseId])
}

/// Active content viewing session. Ephemeral in Redis with TTL;
/// persisted to database for audit and analytics.
model ContentViewingSession {
  id                        String          @id @default(cuid())
  tenantId                  String
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  // ── Identifiers ──
  userId                    String
  licenceId                 String
  resourceId                String
  deviceFingerprint         String

  // ── Session State ──
  status                    String          @default("active") // active | idle | expired | terminated
  startedAt                 DateTime        @default(now())
  lastHeartbeatAt           DateTime        @default(now())
  endedAt                   DateTime?
  expiresAt                 DateTime

  // ── Activity ──
  pagesViewed               Int[]           // Page numbers accessed
  totalPageViews            Int             @default(0)
  peakConcurrentPages       Int             @default(0)
  ipAddress                 String
  userAgent                 String

  // ── Termination ──
  terminatedReason          String?

  @@index([tenantId, licenceId, status])
  @@index([tenantId, resourceId, status])
  @@index([tenantId, userId])
  @@index([expiresAt])
}

/// Per-resource encryption keys (AES-256-GCM). Keys are envelope-
/// encrypted by the tenant master key for at-rest protection.
model ContentEncryptionKey {
  id                        String          @id @default(cuid())
  tenantId                  String
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  // ── Resource ──
  resourceId                String

  // ── Key Material ──
  masterKeyEncrypted        String          // AES-256-GCM key, encrypted
  algorithm                 String          @default("aes-256-gcm")
  keyVersion                Int             @default(1)
  iv                        String          // Initialisation vector (hex)
  authTag                   String          // GCM auth tag (hex)

  // ── Lifecycle ──
  isActive                  Boolean         @default(true)
  rotatedAt                 DateTime?
  rotatedBy                 String?
  previousKeyVersion        Int?

  @@unique([resourceId, keyVersion])
  @@index([tenantId, resourceId, isActive])
}

/// Detected or reported content violation. The incident record
/// linking a leaked file back to its origin via fingerprint matching.
model ContentViolation {
  id                        String          @id @default(cuid())
  tenantId                  String
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  // ── Resource ──
  resourceId                String

  // ── Detection ──
  detectedFingerprint       String?
  matchedDownloadRecordId   String?
  matchedDownloadRecord     DownloadRecord? @relation(fields: [matchedDownloadRecordId], references: [id])
  matchConfidence           Float           @default(0)

  // ── Source ──
  sourceUrl                 String?
  sourceDescription         String
  reportedBy                String
  reportedAt                DateTime        @default(now())

  // ── Matched Identity ──
  matchedUserId             String?
  matchedLicenceId          String?
  matchedInstitutionId      String?
  matchedInstitutionName    String?
  matchedDownloadTimestamp  DateTime?

  // ── Response ──
  severity                  ViolationSeverity @default(medium)
  actionTaken               ViolationAction?
  actionTakenBy             String?
  actionTakenAt             DateTime?
  actionNotes               String?

  // ── Resolution ──
  isResolved                Boolean         @default(false)
  resolvedAt                DateTime?
  resolvedBy                String?
  resolutionNotes           String?

  @@index([tenantId, resourceId])
  @@index([tenantId, isResolved])
  @@index([detectedFingerprint])
}
