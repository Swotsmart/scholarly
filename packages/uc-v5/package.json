    "./plugins/telephony": "./dist/plugins/telephony/index.js",
    "./plugins/whiteboard": "./dist/plugins/whiteboard/index.js",
    "./plugins/cloud-files": "./dist/plugins/cloud-files/index.js",
    "./plugins/ai-transcription": "./dist/plugins/ai-transcription/index.js",
    "./plugins/notifications": "./dist/plugins/notifications/index.js",
    "./plugins/scheduling": "./dist/plugins/scheduling/index.js",
    "./plugins/search-archive": "./dist/plugins/search-archive/index.js",
    "./plugins/analytics": "./dist/plugins/analytics/index.js",
    "./plugins/compliance": "./dist/plugins/compliance/index.js",
    "./plugins/webinar": "./dist/plugins/webinar/index.js",
    "./plugins/webinar/services/write-behind": "./dist/plugins/webinar/services/write-behind-manager.js",
    "./plugins/webinar/services/hls-streaming": "./dist/plugins/webinar/services/hls-streaming.js",
    "./plugins/webinar/services/email-pipeline": "./dist/plugins/webinar/services/registration-email-pipeline.js",
    "./plugins/webinar/services/landing-page": "./dist/plugins/webinar/services/landing-page-generator.js",
    "./plugins/webinar/providers/openai": "./dist/plugins/webinar/providers/openai-provider.js",
    "./plugins/approval-workflow": "./dist/plugins/approval-workflow/index.js",
    "./plugins/approval-workflow/types": "./dist/plugins/approval-workflow/types.js",
    "./plugins/crm-connector": "./dist/plugins/crm-connector/index.js",
    "./plugins/omnichannel-inbox": "./dist/plugins/omnichannel-inbox/index.js",
    "./enhancements": "./dist/enhancements.js",
    "./plugins": "./dist/plugins/index.js",
    "./bus": "./dist/bus/event-bus.js",
    "./bus/events": "./dist/bus/event-types.js",
    "./adapters/prisma": "./dist/adapters/prisma-storage-adapter.js",
    "./adapters/nats": "./dist/adapters/nats-event-bridge.js",
    "./adapters/auth": "./dist/adapters/scholarly-auth-middleware.js"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "peerDependencies": {
    "mediasoup": "^3.13.0",
    "@prisma/client": "^5.9.0",
    "nats": "^2.18.0"
  },
  "peerDependenciesMeta": {
    "mediasoup": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "nats": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
