{
  "name": "@scholarly/unified-communications",
  "version": "5.0.0",
  "description": "Pluggable, event-driven unified communications platform — video conferencing, team chat, telephony, whiteboard, cloud files, approval workflows, contact centre, CRM integration, omnichannel inbox, AI meeting intelligence, real-time translation, and agentic AI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./plugins/video": "./dist/plugins/video/index.js",
