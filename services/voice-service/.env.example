# =============================================================================
# SCHOLARLY VOICE SERVICE — Environment Variables
# Consolidated Sprint 29 + Sprint 30 (Post-ElevenLabs Removal)
# =============================================================================

# --- Deployment Environment ---
SVS_ENVIRONMENT=development        # development | staging | production
SVS_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# --- Compute ---
SVS_TTS_KOKORO_DEVICE=auto          # auto | cuda | cpu
SVS_STT_WHISPER_MODEL_SIZE=large-v3-turbo
SVS_STT_WHISPER_DEVICE=auto

# --- Features ---
# ENABLE_CLONING=false              # Set true + build with --build-arg ENABLE_CLONING=true
# ENABLE_ALIGNMENT=true             # WhisperX alignment (requires wav2vec2 model)

# --- Storage ---
SVS_STORAGE_BACKEND=local_fs        # local_fs | azure_blob
SVS_STORAGE_LOCAL_STORAGE_PATH=/data/voice-assets
# SVS_STORAGE_AZURE_CONNECTION_STRING=  # Required when backend=azure_blob
# SVS_STORAGE_AZURE_CONTAINER_NAME=voice-assets

# --- Cache ---
SVS_CACHE_BACKEND=memory            # memory | redis
# SVS_CACHE_REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
SVS_AUTH_ENABLED=false              # Enable for production
# SVS_AUTH_JWT_SECRET=               # From key vault in production
# SVS_AUTH_JWT_ALGORITHM=HS256

# --- Webhooks ---
SVS_WEBHOOK_ENABLED=false
# SVS_WEBHOOK_TARGET_URL=http://scholarly-api:3000/api/v1/webhooks/voice

# --- Server ---
SVS_SERVER_HOST=0.0.0.0
SVS_SERVER_PORT=8100
SVS_SERVER_WORKERS=4
SVS_SERVER_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# REMOVED (Sprint 30 Wk3) — No external API dependencies:
# ELEVENLABS_API_KEY=
# ELEVENLABS_BASE_URL=
# ELEVENLABS_DEFAULT_MODEL=
# =============================================================================
